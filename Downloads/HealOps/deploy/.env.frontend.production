# ═══════════════════════════════════════════════════════════════════════════════
# HealOps Frontend — Production Environment (.env for apps/frontend/)
# Domain: healops.online
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
ANALYZE=false

# ─── App Config (exposed to browser) ─────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_TITLE=HealOps
NEXT_PUBLIC_APP_NAME=HealOps
NEXT_PUBLIC_APP_URL=https://healops.online
NEXT_PUBLIC_APP_DESCRIPTION="Autonomous Pipeline Healing — AI-powered CI/CD repair"
NEXT_PUBLIC_APP_CATEGORY=devops
NEXT_PUBLIC_APP_KEYWORDS="healops,devops,cicd,pipeline,healing,ai"

# ─── Backend API URL (CRITICAL — this is what the browser uses) ──────────────
# Since Nginx strips /api/ prefix, frontend must call https://healops.online/api
NEXT_PUBLIC_BACKEND_URL=https://healops.online/api

# ─── Analytics (Optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_KEY=GTM-XXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_AUTH_TOKEN=
