# ─────────────────────────────────────────────
# Stage 1: Dependencies (pnpm workspace-aware)
# ─────────────────────────────────────────────
FROM node:20-alpine AS deps

RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@10.26.0

WORKDIR /app

# Copy root workspace config
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./

# Copy ALL workspace package.json files that frontend depends on
COPY apps/frontend/package.json ./apps/frontend/
COPY libs/client_sdk/package.json ./libs/client_sdk/

# Install dependencies for frontend + its workspace deps
RUN pnpm install --frozen-lockfile --filter ./apps/frontend...

# ─────────────────────────────────────────────
# Stage 2: Builder
# ─────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@10.26.0

WORKDIR /app

# Copy installed node_modules (root only is enough for pnpm)
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=deps /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=deps /app/package.json ./package.json

# Copy full source code
COPY apps ./apps
COPY libs ./libs

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

RUN cd apps/frontend && pnpm run build

# ─────────────────────────────────────────────
# Stage 3: Runner
# ─────────────────────────────────────────────
FROM node:20-alpine AS runner

RUN apk add --no-cache libc6-compat curl dumb-init

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Copy standalone build output
COPY --from=builder /app/apps/frontend/public           ./public
COPY --from=builder /app/apps/frontend/.next/standalone ./
COPY --from=builder /app/apps/frontend/.next/static     ./.next/static

RUN chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "server.js"]

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1
