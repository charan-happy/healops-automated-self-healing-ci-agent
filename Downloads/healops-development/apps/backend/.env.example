# ═══════════════════════════════════════════════════════════════════════════════
# HealOps — Environment Configuration
# Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Docker Images (Production) ────────────────────────────────────────────────
# These are used by docker-compose-prod.yml on EC2
BACKEND_IMAGE=ghcr.io/deepanshugoyal10/healops-backend:latest
FRONTEND_IMAGE=ghcr.io/deepanshugoyal10/healops-frontend:latest

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_SECRET=your-random-32-char-secret-for-encryption

# ─── Observability (Prometheus, Grafana, Loki, Jaeger, OpenTelemetry) ─────────
PROMETHEUS_PORT=9090
PROMETHEUS_PUSH_GATEWAY_PORT=9091
PROMTAIL_PORT=9080
NODE_EXPORTER_PORT=9100
NESTJS_METRICS_TARGET=host.docker.internal:3000
NODE_EXPORTER_TARGET=node-exporter:9100
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD="admin"
LOKI_PORT=3100
LOKI_API_TOKEN="admin"
OTLP_PORT=4318
OTEL_SERVICE_NAME=nestjs-app
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_PORT=16686
JAEGER_COLLECTOR_PORT=14268
JAGER_URL=http://localhost:16686

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD="your_password_here"
REDIS_TLS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ─── PostgreSQL Database ─────────────────────────────────────────────────────
# The DB must have the pgvector extension installed:
#   CREATE EXTENSION IF NOT EXISTS vector;
POSTGRES_DB="postgres"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT=5432
POSTGRES_HOST="127.0.0.1"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"

# ─── Pagination ───────────────────────────────────────────────────────────────
DEFAULT_PAGE=1
DEFAULT_PAGE_SIZE=10

# ─── External Links (Dev Tools Dashboard) ────────────────────────────────────
GRAFANA_URL=http://localhost:3001
APP_LOGS_URL=http://localhost:9080/targets
DEV_DOCS_URL=http://localhost:3005
SERVICES_HEALTH_URL=http://localhost:3000/health/health-ui

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Auth (OAuth — Google) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/google/callback

# ─── Auth (OAuth — GitHub) ───────────────────────────────────────────────────
GITHUB_CALLBACK_URL=http://localhost:3000/v1/auth/github/callback

# ─── Auth (OAuth — Apple) ────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Auth (MFA) ──────────────────────────────────────────────────────────────
MFA_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ─── Media (S3) ──────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Media (Cloudinary) ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Notifications (FCM) ─────────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ─── AI (Generic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_PROVIDER=claude

# ═══════════════════════════════════════════════════════════════════════════════
# HEALOPS — AI-Powered CI/CD Repair
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OpenRouter API (LLM) ────────────────────────────────────────────────────
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ─── GitHub App ──────────────────────────────────────────────────────────────
# Create a GitHub App at: https://github.com/settings/apps/new
# Required permissions:
#   Repository: Contents (write), Pull requests (write), Issues (write),
#               Checks (read), Actions (read), Metadata (read)
# Subscribe to webhook events: workflow_run, push
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=Iv1.xxxxxxxxx
GITHUB_CLIENT_SECRET=your-client-secret
GITHUB_WEBHOOK_SECRET=your-random-webhook-secret

# ─── Slack Notifications ─────────────────────────────────────────────────────
# Create an Incoming Webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_DEFAULT_CHANNEL=#eng-healops

# ─── HealOps API (GitHub Actions callback) ───────────────────────────────────
# Local dev: use ngrok or similar tunnel
HEALOPS_PUBLIC_URL=https://your-domain.com
HEALOPS_WEBHOOK_API_KEY=your-random-api-key-for-github-actions-callback

# ─── Agent Configuration ─────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_MIN_CONFIDENCE=0.55
AGENT_TOKEN_BUDGET_PER_JOB=100000
AGENT_MAX_LOG_SNIPPET_TOKENS=8000
AGENT_VECTOR_MIN_SIMILARITY=0.7
AGENT_VECTOR_CLEANUP_DAYS=90

# ─── Cost Control ────────────────────────────────────────────────────────────
MONTHLY_TOKEN_BUDGET=1000000
MONTHLY_JOB_LIMIT=500
COST_INPUT_PRICE_PER_TOKEN=0.000003
COST_OUTPUT_PRICE_PER_TOKEN=0.000015

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# These are used by the Next.js frontend application
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXTAUTH_SECRET=your-random-32-char-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
