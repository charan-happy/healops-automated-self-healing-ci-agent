{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ESNext",
    "moduleResolution": "Node",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    // Strict type checking for better code quality
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    // Additional strict checks
    "maxNodeModuleJsDepth": 20,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "importsNotUsedAsValues": "remove",
    // Path mapping for clean imports
    "baseUrl": "./src",
    "paths": {
      "@nestjs/common": ["../node_modules/@nestjs/common"],
      "@nestjs/common/*": ["../node_modules/@nestjs/common/*"],
      "@nestjs/bullmq": ["../node_modules/@nestjs/bullmq"],
      "@nestjs/bullmq/*": ["../node_modules/@nestjs/bullmq/*"],
      "@nestjs/config": ["../node_modules/@nestjs/config"],
      "@nestjs/config/*": ["../node_modules/@nestjs/config/*"],
      "@nestjs/core": ["../node_modules/@nestjs/core"],
      "@nestjs/core/*": ["../node_modules/@nestjs/core/*"],
      "@nestjs/swagger": ["../node_modules/@nestjs/swagger"],
      "@nestjs/swagger/*": ["../node_modules/@nestjs/swagger/*"],
      "@nestjs/cache-manager": ["../node_modules/@nestjs/cache-manager"],
      "@nestjs/cache-manager/*": ["../node_modules/@nestjs/cache-manager/*"],
      "@nestjs/event-emitter": ["../node_modules/@nestjs/event-emitter"],
      "@nestjs/event-emitter/*": ["../node_modules/@nestjs/event-emitter/*"],
      "@nestjs/throttler": ["../node_modules/@nestjs/throttler"],
      "@nestjs/throttler/*": ["../node_modules/@nestjs/throttler/*"],
      "@common/*": ["common/*"],
      "@middlewares/*": ["middlewares/*"],
      "@interceptors/*": ["interceptors/*"],
      "@config/*": ["config/*"],
      "@logger/*": ["logger/*"],
      "@db/*": ["db/*"],
      "@redis/*": ["redis/*"],
      "@otel/*": ["otel/*"],
      "@bg/constants/job.constant": ["background/constants/job.constant"],
      "@bg/constants/*": ["background/constants/*"],
      "@bg/*": ["background/*"],
      "@cron/*": ["background/cron/*"],
      "@email-queue/*": ["background/queue/email/*"],
      "@notification-queue/*": ["background/queue/notification/*"],
      "@dead-letter-queue/*": ["background/queue/dead-letter/*"],
      "@metrics/*": ["api/metrics/*"],
      "@health/*": ["api/health/*"],
      "@auth/*": ["auth/*"],
      "@users/*": ["users/*"],
      "@media/*": ["media/*"],
      "@email/*": ["email/*"],
      "@sms/*": ["sms/*"],
      "@notifications/*": ["notifications/*"],
      "@ai/*": ["ai/*"],
      // ─── HealOps Aliases ─────────────────────────────────────────────
      "@schema/*": ["db/schema/*"],
      "@github-webhook/*": ["github-webhook/*"],
      "@repair-jobs/*": ["repair-jobs/*"],
      "@repair-agent/*": ["repair-agent/*"],
      "@github/*": ["github/*"],
      "@validator/*": ["validator/*"],
      "@slack/*": ["slack/*"],
      "@vector-memory/*": ["vector-memory/*"],
      "@cost-tracking/*": ["cost-tracking/*"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/db/drizzle/migrations/schema.ts"
  ]
}
