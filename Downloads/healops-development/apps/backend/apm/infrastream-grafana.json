{
  "title": "InfraStream - DevOps Event Intelligence",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "style": "dark",
  "tags": ["infrastream", "devops", "dora", "kafka", "healops"],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "current": { "text": "1m", "value": "1m" },
        "options": [
          { "text": "15s", "value": "15s" },
          { "text": "30s", "value": "30s" },
          { "text": "1m", "value": "1m" },
          { "text": "5m", "value": "5m" },
          { "text": "15m", "value": "15m" }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Event Pipeline",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events Ingestion Rate",
      "description": "Rate of events flowing through Kafka per second",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(infrastream_events_total[$interval]))",
          "legendFormat": "Total Events/s",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "axisCenteredZero": false,
            "axisLabel": "events/s"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Event Processing Latency (p50 / p90 / p99)",
      "description": "Histogram quantile latency of the event processing pipeline",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(infrastream_processing_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P50 Latency",
          "format": "time_series",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(infrastream_processing_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P90 Latency",
          "format": "time_series",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(infrastream_processing_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P99 Latency",
          "format": "time_series",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "axisLabel": "seconds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Events by Type",
      "description": "Stacked breakdown of events: push, PR, deploy, incident, alert, build",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(infrastream_events_total[$interval])) by (type)",
          "legendFormat": "{{type}}",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "push" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "pr" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deploy" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "incident" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF7383", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "alert" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "build" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FADE2A", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "barWidth": 0.8,
        "stacking": "normal",
        "showValue": "auto",
        "groupWidth": 0.7
      }
    },
    {
      "type": "row",
      "title": "DORA Metrics",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "DORA: Deployment Frequency",
      "description": "Deployments per day. Elite: >1/day, High: 1/week-1/day, Medium: 1/month-1/week, Low: <1/month",
      "gridPos": { "x": 0, "y": 15, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_deployment_frequency",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "deploys/day",
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 0.03 },
              { "color": "#FADE2A", "value": 0.14 },
              { "color": "#73BF69", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "DORA: Lead Time for Changes",
      "description": "Hours from commit to production. Elite: <1h, High: <24h, Medium: <168h, Low: >168h",
      "gridPos": { "x": 6, "y": 15, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_lead_time_hours",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "max": 720,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 24 },
              { "color": "#FF9830", "value": 168 },
              { "color": "#FF4444", "value": 720 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "DORA: Change Failure Rate",
      "description": "Percentage of deployments causing failures. Elite: 0-15%, High: 16-30%, Medium: 31-45%, Low: >45%",
      "gridPos": { "x": 12, "y": 15, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_change_failure_rate * 100",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 15 },
              { "color": "#FF9830", "value": 30 },
              { "color": "#FF4444", "value": 45 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "DORA: Mean Time to Recovery",
      "description": "Hours to restore service after failure. Elite: <1h, High: <24h, Medium: <168h, Low: >168h",
      "gridPos": { "x": 18, "y": 15, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_mttr_hours",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "max": 336,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#FF9830", "value": 24 },
              { "color": "#FF4444", "value": 168 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "Infrastructure Health",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active Incidents",
      "description": "Current number of unresolved incidents",
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_active_incidents",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#FF9830", "value": 3 },
              { "color": "#FF4444", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "description": "Consumer group lag indicating processing backlog across partitions",
      "gridPos": { "x": 6, "y": 22, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_kafka_consumer_lag",
          "legendFormat": "{{partition}}",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "axisLabel": "messages"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Total Events Processed (24h)",
      "description": "Total events processed in the last 24 hours",
      "gridPos": { "x": 0, "y": 27, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(infrastream_events_total[24h]))",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "row",
      "title": "Data Layer Performance",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "PostgreSQL Query Duration",
      "description": "P50 / P90 / P99 latency of PostgreSQL queries",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(infrastream_pg_query_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P50",
          "format": "time_series",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(infrastream_pg_query_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P90",
          "format": "time_series",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(infrastream_pg_query_duration_seconds_bucket[$interval])) by (le))",
          "legendFormat": "P99",
          "format": "time_series",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "axisLabel": "seconds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Valkey Cache Hit Rate",
      "description": "Ratio of cache hits to total lookups (hits + misses). Target: >90%",
      "gridPos": { "x": 12, "y": 31, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(infrastream_valkey_cache_hits / (infrastream_valkey_cache_hits + infrastream_valkey_cache_misses)) * 100",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 50 },
              { "color": "#FADE2A", "value": 75 },
              { "color": "#73BF69", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HealOps Healing Events",
      "description": "Self-healing events triggered by HealOps, broken down by status (success, failed, in_progress)",
      "gridPos": { "x": 18, "y": 31, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(infrastream_healops_healing_total[$interval])) by (status)",
          "legendFormat": "{{status}}",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF4444", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "in_progress" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "healed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#10b981", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "detected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "row",
      "title": "User Analytics & Traffic",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Total Visitors (24h)",
      "description": "Unique visitors in the last 24 hours",
      "gridPos": { "x": 0, "y": 39, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(infrastream_http_requests_total[24h]))",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null },
              { "color": "#73BF69", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Active Users (Now)",
      "description": "Currently active users on the platform",
      "gridPos": { "x": 6, "y": 39, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "infrastream_active_users",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FADE2A", "value": null },
              { "color": "#73BF69", "value": 5 },
              { "color": "#5794F2", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Concurrent Users (Peak)",
      "description": "Peak concurrent users in last 24h",
      "gridPos": { "x": 12, "y": 39, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max_over_time(infrastream_concurrent_users[24h])",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
