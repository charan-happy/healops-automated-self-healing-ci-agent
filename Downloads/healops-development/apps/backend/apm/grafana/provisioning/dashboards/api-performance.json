{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total HTTP Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "total_http_requests",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Concurrent Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "concurrent_http_requests",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Users (5m)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "active_users_gauge",
          "legendFormat": "Users",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(api_request_errors_total[5m])) / sum(rate(api_requests_total[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Mobile vs Web Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "total_mobile_requests",
          "legendFormat": "Mobile",
          "refId": "A"
        },
        {
          "expr": "total_web_requests",
          "legendFormat": "Web",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "sum by(route, method) (rate(api_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "pointSize": 3 }
        }
      }
    },
    {
      "title": "Error Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "sum by(route, method, status) (rate(api_request_errors_total[5m]))",
          "legendFormat": "{{method}} {{route}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "API Latency by Route (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, route) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, route) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, route) (rate(api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "sum by(status) (rate(api_requests_total[5m]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        }
      },
      "overrides": [
        {
          "matcher": { "id": "byRegexp", "options": ".*2[0-9]{2}.*" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
        },
        {
          "matcher": { "id": "byRegexp", "options": ".*4[0-9]{2}.*" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
        },
        {
          "matcher": { "id": "byRegexp", "options": ".*5[0-9]{2}.*" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
        }
      ]
    },
    {
      "title": "Requests by User Agent",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "sum by(browser) (api_requests_by_user_agent)",
          "legendFormat": "{{browser}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top Referrers",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 23 },
      "targets": [
        {
          "expr": "topk(10, sum by(referer) (api_requests_by_referer))",
          "legendFormat": "{{referer}}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] } }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["healops", "api", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HealOps — API Performance",
  "uid": "healops-api-performance",
  "version": 1
}
