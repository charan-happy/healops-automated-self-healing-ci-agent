# ═══════════════════════════════════════════════════════════════════════════════
# HealOps Backend — Production Environment (.env for apps/backend/)
# Instance: t3.large (or t3.medium for budget)
# Domain: healops.online
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGINS=https://healops.online,https://www.healops.online
FRONTEND_URL=https://healops.online
APP_SECRET=CHANGE_ME_random_32_char_secret_here_abc123

# ─── PostgreSQL (running on same EC2 via Docker) ─────────────────────────────
POSTGRES_DB=healops
POSTGRES_USER=healops
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1
DATABASE_URL=postgresql://healops:CHANGE_ME_strong_db_password_here@127.0.0.1:5432/healops

# ─── Redis (running on same EC2 via Docker) ──────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_TLS_ENABLED=false
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@127.0.0.1:6379

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_char_jwt_secret_for_production_use_openssl_rand
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Auth (MFA) ──────────────────────────────────────────────────────────────
MFA_ENCRYPTION_KEY=CHANGE_ME_32_char_mfa_key_here__

# ─── Auth (OAuth — Google) — Optional ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://healops.online/api/v1/auth/google/callback

# ─── Auth (OAuth — GitHub) ───────────────────────────────────────────────────
GITHUB_CALLBACK_URL=https://healops.online/api/v1/auth/github/callback

# ─── Auth (OAuth — Apple) — Optional ─────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Pagination ──────────────────────────────────────────────────────────────
DEFAULT_PAGE=1
DEFAULT_PAGE_SIZE=10

# ─── Media (S3) — Optional ───────────────────────────────────────────────────
S3_BUCKET=healops-media
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Email (SMTP) — Optional ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@healops.online

# ─── AWS (SES fallback) — Optional ───────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── SMS (Twilio) — Optional ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Notifications (FCM) — Optional ─────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_PROVIDER=claude

# ═══════════════════════════════════════════════════════════════════════════════
# HEALOPS — CI/CD Repair Engine
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OpenRouter API (LLM for repair agent) ───────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ─── GitHub App ──────────────────────────────────────────────────────────────
GITHUB_APP_ID=CHANGE_ME
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_WEBHOOK_SECRET=CHANGE_ME_random_webhook_secret

# ─── Slack Notifications — Optional ──────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=#eng-healops

# ─── HealOps Public URL (for GitHub Actions callback) ────────────────────────
HEALOPS_PUBLIC_URL=https://healops.online/api
HEALOPS_WEBHOOK_API_KEY=CHANGE_ME_random_api_key

# ─── Agent Configuration ────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_MIN_CONFIDENCE=0.55
AGENT_TOKEN_BUDGET_PER_JOB=100000
AGENT_MAX_LOG_SNIPPET_TOKENS=8000
AGENT_VECTOR_MIN_SIMILARITY=0.7
AGENT_VECTOR_CLEANUP_DAYS=90

# ─── Cost Control ────────────────────────────────────────────────────────────
MONTHLY_TOKEN_BUDGET=1000000
MONTHLY_JOB_LIMIT=500
COST_INPUT_PRICE_PER_TOKEN=0.000003
COST_OUTPUT_PRICE_PER_TOKEN=0.000015

# ─── Observability (optional — only if running monitoring stack) ─────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_URL=https://healops.online:3001
LOKI_PORT=3100
LOKI_API_TOKEN=admin
JAEGER_PORT=16686
JAGER_URL=http://127.0.0.1:16686
OTEL_SERVICE_NAME=healops-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
