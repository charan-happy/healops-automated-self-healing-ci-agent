# Copy this to terraform.tfvars and fill in your values
aws_region              = "ap-south-1"
environment             = "production"
app_name                = "healops"
ec2_instance_type       = "t3.large"
ec2_volume_size_gb      = 30
ssh_allowed_cidr        = "YOUR_IP/32"
create_ssh_key          = true
create_media_bucket     = true
vpc_cidr                = "10.0.0.0/16"
public_subnet_cidr      = "10.0.1.0/24"
postgres_password       = "CHANGE_ME"
redis_password          = "CHANGE_ME"
jwt_secret              = "CHANGE_ME_32_CHARS_MIN"
github_app_id           = "CHANGE_ME"
github_app_private_key  = "CHANGE_ME"
github_webhook_secret   = "CHANGE_ME"
openrouter_api_key      = "CHANGE_ME"
slack_webhook_url       = "CHANGE_ME"
healops_webhook_api_key = "CHANGE_ME"
grafana_admin_password  = "CHANGE_ME"